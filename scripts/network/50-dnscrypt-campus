#!/usr/bin/env bash
# /etc/NetworkManager/dispatcher.d/50-dnscrypt-campus
# Auto-allow UNISA DNS while keeping DNS kill-switch ON
# chmod +x /etc/NetworkManager/dispatcher.d/50-dnscrypt-campus
# systemctl restart NetworkManager

set -euo pipefail

IFACE="${1:-}"
STATUS="${2:-}"

# Act on up/down (NM can call multiple times; script is idempotent)
case "$STATUS" in
  up|down|vpn-up|vpn-down) ;;
  *) exit 0 ;;
esac

STATE_FILE="/var/lib/dnscrypt-toggle/enabled"   # toggle marker
TAG="dnscrypt-campus"

# UNISA resolvers (IPv4)
DNS1="193.205.160.3"
DNS2="193.205.160.139"

is_toggle_enabled() {
  [[ -f "$STATE_FILE" ]]
}

active_wifi_ssid() {
  nmcli -t -f ACTIVE,SSID dev wifi 2>/dev/null | awk -F: '$1=="yes"{print $2; exit}'
}

is_eduroam() {
  command -v nmcli >/dev/null 2>&1 || return 1
  [[ "$(active_wifi_ssid)" == "eduroam" ]]
}

ip_in_unisa_range() {
  # UNISA eduroam fingerprint: 172.19.128.0/17
  local ip
  ip="$(ip -4 addr show dev "$IFACE" 2>/dev/null | awk '/inet /{print $2}' | head -n1 | cut -d/ -f1)"
  [[ -n "${ip:-}" ]] || return 1
  [[ "$ip" =~ ^172\.19\.(12[8-9]|1[3-9][0-9]|2[0-5][0-9])\. ]]
}

gw_is_unisa() {
  # UNISA eduroam fingerprint gateway
  local gw
  gw="$(ip -4 route show default 2>/dev/null | awk '{print $3}' | head -n1)"
  [[ "$gw" == "172.19.255.254" ]]
}

is_campus() {
  # Strict: eduroam + (gateway match OR IP range match)
  is_eduroam || return 1
  gw_is_unisa && return 0
  ip_in_unisa_range && return 0
  return 1
}

ufw_has_rule_like() {
  # Best-effort match on ufw status output
  sudo ufw status | grep -Fq "$1"
}

add_campus_allows() {
  # Insert at top so it matches before the deny-out 53 rules
  # Scope to interface (safer): rule only applies on this Wi-Fi iface
  for ip in "$DNS1" "$DNS2"; do
    ufw_has_rule_like "$ip 53/udp" || sudo ufw insert 1 allow out on "$IFACE" to "$ip" port 53 proto udp >/dev/null
    ufw_has_rule_like "$ip 53/tcp" || sudo ufw insert 1 allow out on "$IFACE" to "$ip" port 53 proto tcp >/dev/null
  done
}

remove_campus_allows() {
  # Remove by exact spec (ignore errors)
  for ip in "$DNS1" "$DNS2"; do
    sudo ufw delete allow out on "$IFACE" to "$ip" port 53 proto udp >/dev/null 2>&1 || true
    sudo ufw delete allow out on "$IFACE" to "$ip" port 53 proto tcp >/dev/null 2>&1 || true
    # Cleanup also generic rules if they exist from old versions
    sudo ufw delete allow out to "$ip" port 53 proto udp >/dev/null 2>&1 || true
    sudo ufw delete allow out to "$ip" port 53 proto tcp >/dev/null 2>&1 || true
  done
}

main() {
  # If toggle isn't enabled, don't touch firewall automatically
  if ! is_toggle_enabled; then
    exit 0
  fi

  if [[ "$STATUS" == "down" || "$STATUS" == "vpn-down" ]]; then
    logger -t "$TAG" "link down -> removing campus DNS allows"
    remove_campus_allows
    sudo ufw reload >/dev/null 2>&1 || true
    exit 0
  fi

  # STATUS is up/vpn-up
  if is_campus; then
    logger -t "$TAG" "UNISA eduroam detected -> allowing DNS only to $DNS1,$DNS2"
    add_campus_allows
  else
    logger -t "$TAG" "non-campus -> removing campus DNS allows"
    remove_campus_allows
  fi

  sudo ufw reload >/dev/null 2>&1 || true
}

main

